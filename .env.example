# ============================================
# XIB (Security in a Box) — Umbrella Config
# ============================================
# Sub-project .env files are managed independently under each subfolder.
# Run `make setup` to initialise all sub-project environments.
# Run `make setup-sso` to wire up Grafana SSO + PIB OIDC after first start.
# ============================================

# ==================== XIB Grafana ====================
XIB_GRAFANA_PORT=3000
XIB_GRAFANA_PASSWORD=CHANGE_ME

# ==================== Grafana SSO (via Authentik/IIB) ====================
# Set by `make setup-sso` — do not set manually.
GRAFANA_SSO_ENABLED=false
GRAFANA_SSO_AUTO_LOGIN=false
AUTHENTIK_GRAFANA_CLIENT_ID=
AUTHENTIK_GRAFANA_CLIENT_SECRET=

# ==================== PIB OIDC (via Authentik/IIB) ====================
# Set by `make setup-sso` — do not set manually.
AUTHENTIK_STEPCA_CLIENT_ID=
AUTHENTIK_STEPCA_CLIENT_SECRET=

# ==================== Integration settings ====================
# External URL where the browser can reach Authentik (IIB).
# Used for OAuth redirect URLs in Grafana.
AUTHENTIK_EXTERNAL_URL=http://localhost:9080

# Hostname used when building Grafana redirect URIs for the Authentik app.
# Change this to your homelab hostname if not running on localhost.
XIB_HOST=localhost
