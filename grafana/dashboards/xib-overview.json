      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 2 },
      "datasource": { "type": "prometheus", "uid": "vib-vm" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          },
          "unit": "short",
          "mappings": []
        },
        "overrides": []
      },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "vib-vm" },
          "expr": "sum(last_over_time(vib_vulnerabilities_total{severity=\"CRITICAL\"}[8h])) or vector(0)",
