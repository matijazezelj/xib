    {
      "id": 40,
      "type": "table",
      "title": "Policy Violations Breakdown",
      "description": "Per-container CIS policy violations from last scan. Red = violation active.",
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 20 },
      "datasource": { "type": "prometheus", "uid": "cib-vm" },
      "fieldConfig": {
        "defaults": {
          "custom": { "align": "left", "displayMode": "auto", "filterable": true },
          "unit": "short"
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "container" },
            "properties": [
              { "id": "displayName", "value": "Container" },
              { "id": "custom.width", "value": 260 }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "check" },
            "properties": [
              { "id": "displayName", "value": "Check — How to fix" },
              { "id": "custom.width", "value": 480 },
              {
                "id": "mappings",
                "value": [
                  {
                    "type": "value",
                    "options": {
                      "memory_limit":      { "text": "memory_limit — add deploy.resources.limits.memory in compose", "index": 0 },
                      "cpu_limit":         { "text": "cpu_limit — add deploy.resources.limits.cpus in compose", "index": 1 },
                      "no_new_privileges": { "text": "no_new_privileges — add security_opt: ['no-new-privileges:true']", "index": 2 },
                      "non_root_user":     { "text": "non_root_user — set user: '1000' (any non-root UID)", "index": 3 },
                      "read_only_rootfs":  { "text": "read_only_rootfs — add read_only: true to service", "index": 4 },
                      "not_privileged":    { "text": "not_privileged — remove privileged: true from HostConfig", "index": 5 },
                      "no_host_network":   { "text": "no_host_network — remove network_mode: host", "index": 6 },
                      "no_host_pid":       { "text": "no_host_pid — remove pid: host", "index": 7 }
                    }
                  }
                ]
              }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Value" },
            "properties": [
              { "id": "displayName", "value": "Status" },
              { "id": "custom.width", "value": 120 },
              { "id": "custom.displayMode", "value": "color-background" },
              { "id": "color", "value": { "mode": "thresholds" } },
              { "id": "thresholds", "value": { "mode": "absolute", "steps": [{ "color": "red", "value": null }] } },
              {
                "id": "mappings",
                "value": [
                  {
                    "type": "value",
                    "options": { "1": { "text": "VIOLATION", "color": "red", "index": 0 } }
                  }
                ]
              }
            ]
          }
        ]
      },
      "options": {
        "footer": { "show": false },
        "showHeader": true,
        "sortBy": [{ "displayName": "Container", "desc": false }]
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "cib-vm" },
          "expr": "last_over_time(cib_policy_violation[8h]) == 1",
          "instant": true,
          "legendFormat": "",
          "refId": "A",
          "format": "table"
        }
      ],
      "transformations": [
        {
          "id": "filterFieldsByName",
          "options": {
            "include": { "names": ["container", "check", "Value"] }
          }
        },
        {
          "id": "sortBy",
          "options": { "fields": [{ "displayName": "container", "desc": false }] }
        }
      ]
    },
